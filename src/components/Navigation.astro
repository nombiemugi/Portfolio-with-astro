---
import "../styles/global.css";
import { getLangFromUrl, useTranslations, localizePath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { href: localizePath('/', lang), label: t('nav.home') },
  { href: localizePath('/projects', lang), label: t('nav.projects') },
  { href: localizePath('/about', lang), label: t('nav.about') },
  { href: localizePath('/contact', lang), label: t('nav.contact') },
];
---

  <ul class="hidden sm:flex m-0 gap-[10px] items-center text-[12px] md:text-[16px] lg:text-[24px] font-medium tracking-(--tracking-tightest)">
    <li>
      {navLinks.map((link) => (
        <a href={link.href} class="hover:text-[var(--accent)] pr-4">{link.label}</a>
      ))}
    </li>
  </ul>
