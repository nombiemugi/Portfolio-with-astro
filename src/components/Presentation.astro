---
import '../styles/global.css';
import Slash from "../assets/svg/slash.svg";
import Palette from "../assets/svg/palette.svg";
import Translate from "../assets/svg/translate.svg";
import Cv from "../assets/svg/cv.svg";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Locale-specific resume: English CV on /, Spanish CV on /es/
const cvFile = t('hero.cvFile');
const cvFileName = cvFile.replace('/', '');
---


<div class="block md:hidden pt-1 pb-2 px-4 text-center">
    <div class="w-1/2 mx-auto max-w-[200px] rounded-full overflow-hidden">
        <img src="/Me-squared1.webp" alt="Andres Soler" class="w-full h-full object-cover">
    </div>
</div>


<section class="md:min-h-screen flex items-center justify-center text-[var(--text)] mb-2">
    <div class="flex flex-col xl:flex-row items-center justify-center gap-2 px-4 ">
        <div class="text-center xl:text-left">
            <h1 class="text-[30px] md:text-[50px] lg:text-[70px] xl:text-[96px] leading-[1] font-bold tracking-(--tracking-tightest)">
                {t('hero.line1')}<span class="hidden md:inline"><br></span>
                {t('hero.line2')}<span class="hidden md:inline"><br></span>
                Andres Soler
              </h1>
            <p class="text-[15px] lg:text-[30px] xl:text-[40px] mb-6-xl mb-0 ">{t('hero.subtitle1')}<br>
                {t('hero.subtitle2')}</p>
                <div class="mt-8 hidden xl:flex flex-col lg:flex-row gap-1 text-[18px] lg:text-[36px] font-bold">
                    <span class="bg-[var(--accent)] text-[var(--color100)] px-8 py-3 rounded-full min-w-[268px] min-h-[77px] flex items-center justify-center gap-4"><Slash />{t('hero.badge.developer')}</span>
                    <span class="bg-[var(--accent)] text-[var(--color100)] px-8 py-3 rounded-full min-w-[268px] min-h-[77px] flex items-center justify-center gap-4"><Palette />{t('hero.badge.designer')}</span>
                    <span class="bg-[var(--accent)] text-[var(--color100)] px-8 py-3 rounded-full min-w-[268px] min-h-[77px] flex items-center justify-center gap-4"><Translate />{t('hero.badge.polyglot')}</span>
                </div>

           <!-- download button -->
        <div class="flex flex-row sm:flex-row justify-center xl:justify-start gap-4 mt-5 text-[20px] lg:text-[32px] font-bold">
            <a
            href={cvFile}
            download={cvFileName}
            class="bg-[var(--accent)] text-[var(--color100)] hover:shadow-[0_0_20px_var(--accent)] hover:bg-[var(--accent-glow)] px-4 py-2 lg:px-6 lg:py-3 rounded-full min-w-[210px] min-h-[48px] lg:min-w-[268px] lg:min-h-[77px] flex items-center justify-center gap-3 lg:gap-4 block transform transition duration-300 hover:scale-105"
            >
            <Cv /> {t('hero.resume')}
            </a>
        </div>

        <!-- image -->
        </div>
        <div class="hidden md:block w-1/2 md:w-1/2 lg:w-1/3 rounded-full overflow-hidden">
            <img src="/Me-squared1.webp" alt="Andres Soler" class="w-full h-full object-cover">
        </div>
    </div>
</section>
