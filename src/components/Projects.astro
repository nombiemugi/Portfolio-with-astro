---
import '../styles/global.css';
import '../styles/tokens.css';
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = await getCollection('projects', ({ slug }) => slug.startsWith(`${lang}/`));

const sortedProjects = [...projects].sort((a, b) => {
  const orderA = Number(a.data.order ?? 999);
  const orderB = Number(b.data.order ?? 999);
  return orderA - orderB;
});
---

<div class="mt-10 space-y-6 mx-8 sm:mx-10 lg:mx-50">
    <!-- TITLE -->
    <div class="m-16 flex items-center justify-center text-center px-4">
        <h2 class="text-[20px] md:text-[42px] lg:text-[64px] font-bold tracking-tighter">
            {t('projects.latest')}
        </h2>
    </div>

    <!-- PROJECTS GRID -->
    <section aria-label={t('projects.aria')} class="mt-10">
        <div class="grid gap-6 md:grid-cols-2">
            {sortedProjects.slice(0, 2).map((project) => (
                <ProjectCard project={project} />
            ))}
        </div>
        <div class="md:col-span-2 mt-4 text-right">
            <a href={localizePath('/projects', lang)}>
                <p class="inline-block text-[var(--accent)] hover:text-[var(--accent-glow)] transition-colors duration-300 font-semibold cursor-pointer">
                    {t('projects.viewAll')} &rarr;
                </p>
            </a>
        </div>
    </section>
</div>
